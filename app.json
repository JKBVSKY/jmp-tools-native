{
  "expo": {
    "scheme": "jmp-tools-native",
    "name": "JMP-Tools-Native",
    "slug": "JMP-Tools-Native",
    "version": "0.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jmp.tools.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jmp.tools.app"
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundleInput": "index.web.js",
      "output": "static",
      "backgroundColor": "#ffffff",
      "themeColor": "#000000",
      "config": {
        "router": {
          "origin": false
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID.",
          "onlyIncludeOnIos": true
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0482ac8-dd67-4d2c-acb3-43e44322379e"
      }
    },
    "owner": "jacob711"
  }
}